{
  "info": {
    "name": "Trello MCP HTTP",
    "description": "Collection para testar o servidor MCP do Trello via HTTP (JSON-RPC 2.0).\n\nFluxo recomendado:\n1. Configure as variáveis `trello_api_key` e `trello_token` no environment.\n2. Execute **Initialize** — o `mcp-session-id` é salvo automaticamente.\n3. Execute qualquer tool na ordem desejada.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Initialize",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "function parseMcpResponse() {",
              "    var body = pm.response.text();",
              "    var dataLine = body.split('\\n').find(l => l.startsWith('data:'));",
              "    return JSON.parse(dataLine.replace(/^data:\\s*/, ''));",
              "}",
              "",
              "// Salva o session id retornado no header",
              "var sessionId = pm.response.headers.get('mcp-session-id');",
              "if (sessionId) {",
              "    pm.environment.set('mcp_session_id', sessionId);",
              "    console.log('mcp-session-id salvo:', sessionId);",
              "} else {",
              "    console.warn('Header mcp-session-id não encontrado na resposta.');",
              "}",
              "",
              "// Valida que a resposta é 200 e tem result",
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Resposta contém result', function () {",
              "    var json = parseMcpResponse();",
              "    pm.expect(json).to.have.property('result');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Trello-Api-Key", "value": "{{trello_api_key}}" },
          { "key": "X-Trello-Token", "value": "{{trello_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 1,\n  \"method\": \"initialize\",\n  \"params\": {\n    \"protocolVersion\": \"2024-11-05\",\n    \"capabilities\": {},\n    \"clientInfo\": {\n      \"name\": \"postman\",\n      \"version\": \"1.0\"\n    }\n  }\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/mcp",
          "host": ["{{base_url}}"],
          "path": ["mcp"]
        },
        "description": "Inicia a sessão MCP. O `mcp-session-id` retornado no header é salvo automaticamente na variável de environment `mcp_session_id`."
      }
    },
    {
      "name": "2. List Tools",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "function parseMcpResponse() {",
              "    var body = pm.response.text();",
              "    var dataLine = body.split('\\n').find(l => l.startsWith('data:'));",
              "    return JSON.parse(dataLine.replace(/^data:\\s*/, ''));",
              "}",
              "",
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Resposta contém lista de tools', function () {",
              "    var json = parseMcpResponse();",
              "    pm.expect(json.result).to.have.property('tools');",
              "    pm.expect(json.result.tools).to.be.an('array');",
              "    console.log('Tools disponíveis:', json.result.tools.map(t => t.name));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Trello-Api-Key", "value": "{{trello_api_key}}" },
          { "key": "X-Trello-Token", "value": "{{trello_token}}" },
          { "key": "mcp-session-id", "value": "{{mcp_session_id}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 2,\n  \"method\": \"tools/list\",\n  \"params\": {}\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/mcp",
          "host": ["{{base_url}}"],
          "path": ["mcp"]
        },
        "description": "Lista todas as tools disponíveis no servidor MCP."
      }
