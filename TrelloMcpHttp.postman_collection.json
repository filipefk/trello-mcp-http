      "item": [
        {
          "name": "get_boards",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Retornou boards', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.result).to.have.property('content');",
                  "});",
                  "",
                  "// Salva o ID do primeiro board encontrado",
                  "try {",
                  "    var json = pm.response.json();",
                  "    var content = json.result.content[0].text;",
                  "    var boards = JSON.parse(content);",
                  "    if (boards.length > 0) {",
                  "        pm.environment.set('board_id', boards[0].id);",
                  "        pm.environment.set('board_name', boards[0].name);",
                  "        console.log('board_id salvo:', boards[0].id, '| Nome:', boards[0].name);",
                  "    }",
                  "} catch (e) {",
                  "    console.warn('Não foi possível extrair board_id:', e.message);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Trello-Api-Key", "value": "{{trello_api_key}}" },
              { "key": "X-Trello-Token", "value": "{{trello_token}}" },
              { "key": "mcp-session-id", "value": "{{mcp_session_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 10,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"get_boards\",\n    \"arguments\": {}\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/mcp",
              "host": ["{{base_url}}"],
              "path": ["mcp"]
            },
            "description": "Lista todos os boards do usuário autenticado. Salva automaticamente o `board_id` e `board_name` do primeiro board na variável de environment."
          }
        },
        {
          "name": "get_board_id_by_name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () {",
