            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Trello-Api-Key", "value": "{{trello_api_key}}" },
              { "key": "X-Trello-Token", "value": "{{trello_token}}" },
              { "key": "mcp-session-id", "value": "{{mcp_session_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"id\": 11,\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"get_board_id_by_name\",\n    \"arguments\": {\n      \"board_name\": \"Meu Board\"\n    }\n  }\n}",
